{
	"name": "client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"ts:check": "tsc -p ./tsconfig.app.json --noEmit",
		"lint": "biome lint --diagnostic-level=error --no-errors-on-unmatched",
		"lint:fix": "biome lint --write --no-errors-on-unmatched",
		"format": "biome format --write --no-errors-on-unmatched",
		"ci": "biome ci .",
		"preview": "vite preview",
		"fsd": "steiger ./src",
		"knip": "knip -c knip.config.jsonc",
		"check-all": "npm run ts:check && npm run lint && npm run format && npm run fsd && npm run knip",
		"lint-staged": "lint-staged",
		"gen:types": "supabase gen types typescript --local --workdir ../server > src/shared/lib/supabase/generated/types.ts"
	},
	"lint-staged": {
		"**/*.{ts,tsx}": [
			"npm run lint:fix",
			"npm run format"
		]
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@feature-sliced/steiger-plugin": "^0.5.7",
		"@fontsource-variable/geist": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@supabase/supabase-js": "^2.99.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jotai": "^2.18.1",
		"knip": "^5.87.0",
		"lucide-react": "^0.577.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.71.2",
		"react-router-dom": "^7.9.1",
		"shadcn": "^4.0.8",
		"steiger": "^0.5.11",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"lint-staged": "^16.4.0",
		"typescript": "~5.9.3",
		"vite": "^8.0.0"
	}
}
