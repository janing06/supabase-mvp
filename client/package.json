{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "ts:check": "tsc -p ./tsconfig.app.json --noEmit",
    "lint": "biome lint --diagnostic-level=error --no-errors-on-unmatched",
    "lint:fix": "biome lint --write --no-errors-on-unmatched",
    "format": "biome format --write --no-errors-on-unmatched",
    "ci": "biome ci .",
    "preview": "vite preview",
    "fsd": "steiger ./src",
    "knip": "knip -c knip.config.jsonc",
    "check-all": "npm run ts:check && npm run lint && npm run fsd && npm run knip",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "npm run lint:fix",
      "npm run format"
    ]
  },
  "dependencies": {
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "knip": "^5.87.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.1",
    "steiger": "^0.5.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "lint-staged": "^16.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
